# === AI Dev Swarm Configuration ===

# Ollama (free, local -- install from https://ollama.com)
# No API key needed. Just run: ollama pull qwen2.5-coder
# When running in Docker, this points to the Ollama container:
OLLAMA_BASE_URL=http://localhost:11434

# Default worker model -- used for agents that don't have a role-specific model
# Local:  ollama/qwen2.5-coder, ollama/deepseek-coder-v2, ollama/llama3.2
# Cloud:  gpt-4o-mini, anthropic/claude-sonnet-4-20250514
WORKER_MODEL=ollama/qwen2.5-coder:7b

# === Per-Role Model Overrides (optional) ===
# Set these to use different models for different agent roles.
# If unset, each role falls back to WORKER_MODEL.
# Heavier models for roles that need more reasoning:
#PLANNER_MODEL=ollama/qwen2.5-coder:14b
#REVIEWER_MODEL=ollama/qwen2.5-coder:14b
#BUILDER_MODEL=ollama/qwen2.5-coder:7b
#SECURITY_MODEL=ollama/qwen2.5-coder:7b
#PERFORMANCE_MODEL=ollama/qwen2.5-coder:7b
#TESTER_MODEL=ollama/qwen2.5-coder:7b
# Lighter/faster models for simpler tasks:
#REFACTORER_MODEL=ollama/qwen2.5-coder:3b
#DOCS_MODEL=ollama/qwen2.5-coder:3b
#LINTER_MODEL=ollama/qwen2.5-coder:3b

# Mode: "headless" (Cursor is commander) or "full" (standalone)
SWARM_MODE=headless

# === Git Config ===
AUTO_COMMIT=false
BRANCH_PREFIX=swarm/

# === Tool Config ===
SHELL_TIMEOUT=60

# === Docker / Remote Config ===
# Redis URL for the task queue (set by docker-compose, leave empty for local dev)
#REDIS_URL=redis://localhost:6379/0
# Workspace root for task execution
#REPO_ROOT=/workspace
# CORS allowed origins for the API server (comma-separated, or "*" for all).
# For production, restrict this to your frontend URL(s):
#CORS_ORIGINS=https://my-frontend.example.com,https://staging.example.com
