# === AI Dev Swarm Configuration ===

# === Cursor mode (Mac dispatches, Windows runs worker) ===
# Callback: Mac IP for task-done push (auto-detected if unset). Windows POSTs here when done.
#SWARM_CALLBACK_HOST=192.168.1.100
# Option A: Cursor CLI agent (uses your Cursor subscription, no API key)
# On Windows: .\scripts\cursor-worker.ps1 start -CursorAgent
# Or: SWARM_USE_CURSOR_AGENT=1
# Requires: agent login (Cursor CLI), irm 'https://cursor.com/install?win32=true' | iex
#
# Option B: Python worker + cloud model (requires API key)
WORKER_MODEL=gpt-4o-mini
#OPENAI_API_KEY=sk-...   # required for gpt-4o-mini
# Or use Anthropic:
#WORKER_MODEL=anthropic/claude-sonnet-4-20250514
#ANTHROPIC_API_KEY=sk-ant-...

# === Ollama (optional, local) ===
# Uncomment to use local Ollama instead of cloud models.
#OLLAMA_BASE_URL=http://localhost:11434
#WORKER_MODEL=ollama/qwen2.5-coder:7b

# === Per-Role Model Overrides (optional) ===
# If unset, each role falls back to WORKER_MODEL.
# Cloud examples: gpt-4o, anthropic/claude-sonnet-4-20250514
# Ollama examples: ollama/qwen2.5-coder:14b, ollama/qwen2.5-coder:7b
#PLANNER_MODEL=gpt-4o
#REVIEWER_MODEL=gpt-4o-mini
#BUILDER_MODEL=gpt-4o-mini
#SECURITY_MODEL=ollama/qwen2.5-coder:7b
#PERFORMANCE_MODEL=ollama/qwen2.5-coder:7b
#TESTER_MODEL=ollama/qwen2.5-coder:7b
# Lighter/faster models for simpler tasks:
#REFACTORER_MODEL=ollama/qwen2.5-coder:3b
#DOCS_MODEL=ollama/qwen2.5-coder:3b
#LINTER_MODEL=ollama/qwen2.5-coder:3b

# Mode: "headless" (Cursor is commander) or "full" (standalone)
SWARM_MODE=headless

# === Git Config ===
AUTO_COMMIT=false
BRANCH_PREFIX=swarm/

# === Tool Config ===
SHELL_TIMEOUT=60

# === Docker / Remote Config ===
# Redis URL for the task queue (set by docker-compose, leave empty for local dev)
#REDIS_URL=redis://localhost:6379/0
# Workspace root for task execution
#REPO_ROOT=/workspace

# === Multi-machine execution ===
# Default execution backend for MCP and CLI dispatch: local | ollama | cursor
# Remote-first default for Mac->Windows workflow.
DEFAULT_EXECUTION_MODE=cursor

# Windows host connection (used for cursor mode over SSH)
WINDOWS_HOST=
WINDOWS_USER=
#WINDOWS_SSH_KEY=~/.ssh/id_ed25519

# Windows Docker Swarm API endpoint (used for ollama mode)
WINDOWS_SWARM_API=http://localhost:9000

# Optional workspace hint for Windows Cursor agents
WINDOWS_CURSOR_WORKSPACE=

# Cursor worker queue config (cursor mode)
#WINDOWS_CURSOR_QUEUE_ROOT=~/.swarm
#WINDOWS_CURSOR_TIMEOUT=7200
#WINDOWS_CURSOR_HEARTBEAT_TIMEOUT=120

# Keep Ollama models warm on the Windows host to reduce cold-start delays.
# Set this in the Windows environment where Ollama runs.
# Example values: 10m, 30m, -1 (never unload)
#OLLAMA_KEEP_ALIVE=30m
