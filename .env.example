# === AI Dev Swarm Configuration ===

# Ollama (free, local -- install from https://ollama.com)
# No API key needed. Just run: ollama pull qwen2.5-coder
OLLAMA_BASE_URL=http://localhost:11434

# Worker model -- used for all 10 agents (fast + cheap)
# Local:  ollama/qwen2.5-coder, ollama/deepseek-coder-v2, ollama/llama3.2
# Cloud:  gpt-4o-mini, anthropic/claude-sonnet-4-20250514
WORKER_MODEL=ollama/qwen2.5-coder:7b

# Mode: "headless" (Cursor is commander) or "full" (standalone)
SWARM_MODE=headless

# === Git Config ===
# Auto-commit? In headless mode this should be false (Cursor decides)
AUTO_COMMIT=false
# Branch prefix for swarm work
BRANCH_PREFIX=swarm/

# === Tool Config ===
# Max seconds a shell command can run before timeout
SHELL_TIMEOUT=60
